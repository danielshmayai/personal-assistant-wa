# PostgreSQL
POSTGRES_USER=pa
POSTGRES_PASSWORD=changeme          # CHANGE THIS — use a strong random password
POSTGRES_DB=pa

# WAHA
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=changeme    # CHANGE THIS
WAHA_API_KEY=                       # Recommended: openssl rand -hex 32

# Your WhatsApp ID (format: 972501234567@c.us — country code + number, no + or spaces)
MY_WHATSAPP_ID=
# Optional: your WhatsApp @lid (newer multi-device format). Auto-detected at startup.
# Set manually if self-chat detection breaks: find it in backend logs ("own @lid").
MY_WHATSAPP_LID=

# ── Security (all recommended for production) ──────────────────────────────

# Shared secret embedded in the WAHA webhook URL to reject unsigned payloads.
# Generate: openssl rand -hex 32
WEBHOOK_SECRET=

# Bearer token for the dev-only POST /test endpoint. Leave empty to block /test entirely.
# Generate: openssl rand -hex 32
TEST_TOKEN=

# Fernet key for encrypting Google OAuth tokens at rest in PostgreSQL.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: if you lose this key you will need to re-authenticate Google.
DB_ENCRYPTION_KEY=

# ── LLM ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ── Web search ─────────────────────────────────────────────────────────────
# Optional — bot falls back to DuckDuckGo when not set
TAVILY_API_KEY=

# ── Google OAuth ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
OAUTHLIB_INSECURE_TRANSPORT=0

# ── Tuya smart-home ────────────────────────────────────────────────────────
TUYA_ACCESS_ID=
TUYA_ACCESS_KEY=
TUYA_API_ENDPOINT=https://openapi.tuyaeu.com
TUYA_PREFER_LOCAL=false

# ── Obsidian vault (long-term memory) ──────────────────────────────────────
# Path on the HOST to your Obsidian vault. The folder will be bind-mounted
# into the backend container at /app/obsidian_vault. Use forward slashes on
# Windows.
# Examples:
#   Windows native:  D:/Obsidian/MyVault
#   WSL2:            /mnt/d/Obsidian/MyVault
#   In-repo (test):  ./obsidian_vault
HOST_OBSIDIAN_VAULT=D:/Obsidian/MyVault

# Optional: comma-separated whitelist of allowed top-level folder names.
# Off-list categories from the LLM silently fall into "Misc".
OBSIDIAN_CATEGORIES=System,People,Entities,Investments,Projects,Preferences,Misc

# ── Cloudflare Tunnel ──────────────────────────────────────────────────────
# Create at: https://one.dash.cloudflare.com/ → Zero Trust → Networks → Tunnels
# Configure public hostname to route to http://backend:8000
TUNNEL_TOKEN=
